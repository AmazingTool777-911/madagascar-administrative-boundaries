# PostgreSQL connection settings
# These variables map 1-to-1 with the --<flag> CLI arguments accepted by
# the extract-adm-inputs script.  CLI flags always take precedence over
# environment variables when both are provided.
#
# Connection mode — pick ONE of the two sections below:
#
#   URL mode   : set PG_URL (or pass --url).  All individual fields are ignored.
#   Config mode: leave PG_URL unset and fill in the individual fields instead.

# ── URL mode ────────────────────────────────────────────────────────────────
# --pg-url  : Full PostgreSQL connection URL.
#             Format: postgres://<user>:<password>@<host>:<port>/<database>
#             When set, all individual config fields below are ignored.
PG_URL=

# ── Config mode (used when PG_URL is not set) ───────────────────────────────

# --pg-host  : Hostname or IP address of the PostgreSQL server.
PG_HOST=localhost

# --pg-port  : TCP port the PostgreSQL server listens on.
PG_PORT=5432

# --pg-username  : Username to authenticate with.
PG_USERNAME=postgres

# --pg-password  : Password for the above user.
PG_PASSWORD=

# --pg-database  : Name of the target database.
PG_DATABASE=postgres

# --pg-schema  : Name of the physical database schema (default: public).
PG_SCHEMA=public

# --pg-ssl  : Enable SSL for the connection ("true" / "1" = enabled, anything else = disabled).
#             Omit entirely to leave SSL unset (driver default applies).
PG_SSL=false

# ── Redis connection settings ──────────────────────────────────────────────
# These variables map 1-to-1 with the --redis-<flag> CLI arguments accepted by
# the extract-adm-inputs script.  CLI flags always take precedence over
# environment variables when both are provided.
#
# Connection mode — pick ONE of the two sections below:
#
#   URL mode   : set REDIS_URL (or pass --redis-url).  All individual fields are ignored.
#   Config mode: leave REDIS_URL unset and fill in the individual fields instead.

# ── URL mode ────────────────────────────────────────────────────────────────
# --redis-url : Full Redis connection URL.
#               Format: redis://<user>:<password>@<host>:<port>/<db-index>
#               When set, all individual config fields below are ignored.
REDIS_URL=

# ── Config mode (used when REDIS_URL is not set) ───────────────────────────

# --redis-host : Hostname or IP address of the Redis server.
REDIS_HOST=localhost

# --redis-port : TCP port the Redis server listens on.
REDIS_PORT=6379

# --redis-username : Optional username to authenticate with.
REDIS_USERNAME=

# --redis-password : Optional password for the above user.
REDIS_PASSWORD=

# --redis-db : Optional database index (default 0).
REDIS_DB=0

# --redis-ssl : Enable TLS/SSL for the connection ("true" / "1" = enabled, anything else = disabled).
REDIS_SSL=false

# --disable-redis : Disable Redis connection ("true" / "1" = disabled, default = enabled).
DISABLE_REDIS=false

# ── Queue & Worker Mediators settings ──────────────────────────────────────
# These variables control the queue behaviors and fallback gracefully to defaults
# when left unconfigured. They map to CLI flags with similar names, where flags
# take precedence.

# --queue-batch-size : Batch size for processing messages concurrently.
QUEUE_BATCH_SIZE=

# --queue-max-retries : Maximum number of retries per batch in case of an error.
QUEUE_MAX_RETRIES=

# --in-memory-processing-hwm : Default high water mark for in-memory processing workers.
IN_MEMORY_PROCESSING_HWM=

# --in-memory-insert-hwm : Default high water mark for the in-memory insert worker.
IN_MEMORY_INSERT_HWM=

# --worker-healthcheck-interval : Interval for worker healthcheck in milliseconds.
WORKER_HEALTHCHECK_INTERVAL=

# --worker-pending-min-duration-threshold : Threshold for claiming pending messages in milliseconds.
WORKER_PENDING_MIN_DURATION_THRESHOLD=

# --xread-block-duration : Duration in milliseconds for XREAD BLOCK calls in Redis.
#                          Controls how long workers wait for new messages before timing out.
#                          Lower values increase responsiveness, higher values reduce CPU usage.
XREAD_BLOCK_DURATION=

# --processing-workers-count : Number of concurrent processing workers to spawn per ADM level.
#                              Defaults to 2. Increase for better throughput on large datasets.
PROCESSING_WORKERS_COUNT=2
