      "updated": 1775031614974,
      "link": null,
      "locked": false,
      "text": "parent_adm := parent_adm where intersection_area = max(intersection_area(current_adm's geojson, all parent_adm's geojson))",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "parent_adm := parent_adm where intersection_area = max(intersection_area(current_adm's geojson, all parent_adm's geojson))",
