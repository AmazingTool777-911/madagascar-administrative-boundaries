{
  "tasks": {
    "dev": "deno run --watch main.ts",
    "extract-adm-inputs": "deno run --allow-env --allow-net --allow-read --allow-write --env scripts/extract-adm-inputs/extract-adm-inputs.script.ts",
    "test": "deno test -R -E --env"
  },
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@^1.0.1",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.1",
    "@cliffy/testing": "jsr:@cliffy/testing@^1.0.1",
    "@db/postgres": "jsr:@db/postgres@^0.19.5",
    "@iuioiua/redis": "jsr:@iuioiua/redis@^1.1.10",
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/streams": "jsr:@std/streams@^1.0.17"
  },
  "workspace": [
    "./consts",
    "./types",
    "./db",
    "./adapters",
    "./helpers",
    "./redis",
    "./lib",
    "./utils"
  ],
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.unstable",
      "node",
      "deno.ns",
      "deno.worker"
    ]
  },
  "test": {
    "exclude": ["**/*.integration.test.ts"]
  }
}
