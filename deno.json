{
  "tasks": {
    "cli": "deno -E --env -N -R -W commands/index.ts",
    "cli:set-config": "deno -E --env -N -R -W commands/index.ts set-config",
    "cli:update-field": "deno -E --env -N -R -W commands/index.ts update-field",
    "cli:clear": "deno -E --env -N -R -W commands/index.ts clear",
    "build:windows:x86_64": "deno compile -E -N -R -W --target x86_64-pc-windows-msvc --output ./bin/x86_64-pc-windows-msvc/mada-adm --include commands/workers commands/index.ts",
    "build:macos:x86_64": "deno compile -E -N -R -W --target x86_64-apple-darwin --output ./bin/x86_64-apple-darwin/mada-adm --include commands/workers commands/index.ts",
    "build:macos:arm64": "deno compile -E -N -R -W --target aarch64-apple-darwin --output ./bin/aarch64-apple-darwin/mada-adm --include commands/workers commands/index.ts",
    "build:linux:x86_64": "deno compile -E -N -R -W --target x86_64-unknown-linux-gnu --output ./bin/x86_64-unknown-linux-gnu/mada-adm --include commands/workers commands/index.ts",
    "build:linux:arm64": "deno compile -E -N -R -W --target aarch64-unknown-linux-gnu --output ./bin/aarch64-unknown-linux-gnu/mada-adm --include commands/workers commands/index.ts",
    "build": "deno task build:windows:x86_64 && deno task build:macos:x86_64 && deno task build:macos:arm64 && deno task build:linux:x86_64 && deno task build:linux:arm64",
    "extract-adm-inputs": "deno run --allow-env --allow-net --allow-read --allow-write --env scripts/extract-adm-inputs/extract-adm-inputs.script.ts",
    "test": "deno test -R -E --env"
  },
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@^1.0.1",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.1",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.1",
    "@cliffy/table": "jsr:@cliffy/table@^1.0.1",
    "@cliffy/testing": "jsr:@cliffy/testing@^1.0.1",
    "@db/postgres": "jsr:@db/postgres@^0.19.5",
    "@iuioiua/redis": "jsr:@iuioiua/redis@^1.1.10",
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/streams": "jsr:@std/streams@^1.0.17"
  },
  "workspace": [
    "./consts",
    "./types",
    "./db",
    "./adapters",
    "./helpers",
    "./redis",
    "./lib",
    "./utils"
  ],
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.unstable",
      "node",
      "deno.ns",
      "deno.worker"
    ]
  },
  "test": {
    "exclude": ["**/*.integration.test.ts"]
  }
}
